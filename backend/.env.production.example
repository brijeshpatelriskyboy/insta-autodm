# Production environment — backend (Railway / Render)
# Copy values into your hosting provider's environment variable UI.

NODE_ENV=production
PORT=4000

# PostgreSQL — from Railway/Render/Neon/Supabase dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/insta_autodm?schema=public

# Auth — generate: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_MIN_32_CHARS

# Frontend URL (your Vercel deployment — no trailing slash)
CORS_ORIGIN=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Stripe — use test keys first (sk_test_ / price_test_), then live for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxx
STRIPE_PRICE_CREATOR=price_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx

# Optional
META_VERIFY_TOKEN=insta-autodm-verify-token
