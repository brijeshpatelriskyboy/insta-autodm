# Production environment — frontend (Vercel)
# Add these in Vercel → Project → Settings → Environment Variables
# Then redeploy — Next.js bakes these in at build time.

# Backend API URL — your REAL Railway public domain (no trailing slash).
# Copy from Railway → API service → Settings → Networking → Public domain.
# Do NOT use placeholder values like your-api.up.railway.app or YOUR-RAILWAY-DOMAIN.
API_URL=https://insta-autodm-production-xxxx.up.railway.app
NEXT_PUBLIC_API_URL=https://insta-autodm-production-xxxx.up.railway.app

# Public site URL (your Vercel domain — used for SEO/sitemap)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
