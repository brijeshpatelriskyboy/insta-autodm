# =============================================================================
# Insta AutoDM — Environment Variables
# Copy this file to .env (root), backend/.env, and frontend/.env.local
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE_URL
# PostgreSQL connection string used by Prisma (backend).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local default matches docker-compose db service.
# -----------------------------------------------------------------------------
# With Docker Compose (password: postgres):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/insta_autodm?schema=public
# With portable/local PostgreSQL (trust auth, no password):
DATABASE_URL=postgresql://postgres@localhost:5432/insta_autodm?schema=public

# -----------------------------------------------------------------------------
# PORT
# Port the Express backend listens on.
# -----------------------------------------------------------------------------
PORT=4000

# -----------------------------------------------------------------------------
# NODE_ENV
# Runtime environment: development | production | test
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# JWT_SECRET
# Secret key for signing JWT auth tokens. Must be at least 16 characters.
# Use a long random string in production.
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Comma-separated list. Include both localhost and 127.0.0.1 for local dev.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL
# Backend API base URL exposed to the Next.js frontend (browser-accessible).
# Production: your Railway/Render API URL, e.g. https://your-api.up.railway.app
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL (frontend — Vercel)
# Public marketing site URL for SEO/sitemap. Production: https://your-app.vercel.app
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# FRONTEND_URL
# Used for Stripe Checkout success/cancel redirects.
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# STRIPE (optional — required for live billing)
# Create products/prices in Stripe Dashboard, then paste price IDs below.
# Webhook endpoint: POST http://localhost:4000/api/billing/webhook
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_CREATOR=price_...
# STRIPE_PRICE_PRO=price_...

# -----------------------------------------------------------------------------
# Meta / Instagram OAuth (Phase 2b)
# META_APP_ID — from Meta App Dashboard
# META_APP_SECRET — server only, never expose to frontend
# META_REDIRECT_URI — https://YOUR-API/api/integrations/instagram/callback
# META_VERIFY_TOKEN — webhook verification token
# -----------------------------------------------------------------------------
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=http://localhost:4000/api/integrations/instagram/callback
META_VERIFY_TOKEN=insta-autodm-verify-token
